# Copy to `.env` or `.env.local` and adjust. Never commit real secrets.

# Backend host for Vite's development proxy.
API_PROXY_TARGET=http://localhost:5000

# Browser-facing API base path. Must include `/api` because Express mounts routes under `/api`.
# In development, keep this as `/api` so Vite proxies requests to API_PROXY_TARGET.
# In production, replace it with your deployed API origin plus `/api`.
VITE_API_BASE_URL=/api

# Shown in nav, footer, and document title.
VITE_APP_NAME=FOOSE
