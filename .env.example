# Copy to `.env.local` and adjust. Never commit real secrets — the frontend only needs public config.

# Backend API base path. Must include `/api` (Express mounts routes under `/api`).
# Leave unset in development to use Vite’s proxy: browser calls `/api/...` → http://localhost:5000/api/...
VITE_API_BASE_URL=http://backend-env.eba-dp2hwdue.eu-north-1.elasticbeanstalk.com/
Production (replace with your deployed API):
VITE_API_BASE_URL=

# Shown in nav, footer, and document title
VITE_APP_NAME=FOOSE

